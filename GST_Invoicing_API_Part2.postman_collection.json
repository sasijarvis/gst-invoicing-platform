{
  "info": {
    "name": "GST Invoicing API - Part 2 (Invoices, Payments, Recurring)",
    "description": "Comprehensive API collection for GST Invoicing Platform - Part 2\n\nThis collection covers:\n- Invoice Management (CRUD, Items, GST Calculations)\n- Payment Management (Recording, Tracking, Outstanding)\n- Recurring Invoice Management (Subscription Billing)\n\nPrerequisites:\n1. Import Part 1 collection first\n2. Login using Part 1 to get access token\n3. Get customer and product IDs from Part 1\n4. Set the variables below with actual IDs\n\nDemo Credentials:\n- Email: demo@gstinvoicing.com\n- Password: demo123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "Set this from Part 1 login response"
    },
    {
      "key": "customerId",
      "value": "",
      "type": "string",
      "description": "Set this from Part 1 customer response"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string",
      "description": "Set this from Part 1 product response"
    },
    {
      "key": "invoiceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "itemId",
      "value": "",
      "type": "string"
    },
    {
      "key": "paymentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "recurringInvoiceId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Invoice Management",
      "item": [
        {
          "name": "Get Invoice Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/invoices/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invoices", "stats"]
            },
            "description": "Get overview statistics of invoices and amounts"
          }
        },
        {
          "name": "Search Invoices",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/invoices/search?q=INV&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invoices", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "INV"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "Search invoices by invoice number, notes, customer name"
          }
        },
        {
          "name": "Get All Invoices",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.length > 0) {",
                  "        pm.collectionVariables.set('invoiceId', response.data[0].id);",
                  "        console.log('Invoice ID set:', response.data[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/invoices?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invoices"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get all invoices with pagination and automatically set first invoice ID"
          }
        },
        {
          "name": "Create Invoice with Multiple Items",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('invoiceId', response.data.id);",
                  "    console.log('Invoice ID set:', response.data.id);",
                  "    if (response.data.items && response.data.items.length > 0) {",
                  "        pm.collectionVariables.set('itemId', response.data.items[0].id);",
                  "        console.log('Item ID set:', response.data.items[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"invoiceDate\": \"2024-01-15T00:00:00.000Z\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 1,\n      \"description\": \"Primary service item\"\n    },\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 2,\n      \"rate\": 25000,\n      \"description\": \"Additional consulting hours\"\n    }\n  ],\n  \"discountAmount\": 5000,\n  \"notes\": \"Thank you for your business\",\n  \"terms\": \"Payment due within 30 days\",\n  \"status\": \"DRAFT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/invoices",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invoices"]
            },
            "description": "Create invoice with multiple items and automatically set invoice/item IDs"
          }
        },
